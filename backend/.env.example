PORT=4000
CORS_ORIGIN=http://localhost:5173,https://your-portfolio-domain.vercel.app
ADMIN_SECRET_KEY=change-this-secret-key
MAX_UPLOAD_SIZE_MB=5

S3_REGION=auto
S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_BUCKET_NAME=portfolio-resume
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key
S3_PUBLIC_URL_BASE=https://your-public-r2-url/
S3_FORCE_PATH_STYLE=false
RESUME_OBJECT_KEY=resume/ResumeAtif.pdf
